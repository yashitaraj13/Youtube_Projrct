NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB (for future backend migration)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/test

# Razorpay — TEST mode
# NEXT_PUBLIC_ prefix exposes the key ID to the browser (safe for public key only)
# Never expose RAZORPAY_KEY_SECRET to the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx

# Resend — email invoice delivery
# Leave blank or as placeholder to use simulated console-log mode
RESEND_API_KEY=re_xxxxxxxxxx

# Socket.IO signaling server (future WebRTC)
SOCKET_SERVER_URL=http://localhost:5000
